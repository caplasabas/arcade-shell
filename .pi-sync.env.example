# Copy to .pi-sync.env and edit values.

# SSH target, e.g. arcade1@192.168.1.50
PI_REMOTE_HOST=arcade1@192.168.1.50
PI_SSH_PORT=22
PI_SSH_BATCH_MODE=0
# PI_SSH_KEY=/Users/youruser/.ssh/arcade_pi
# PI_SSH_OPTS="-o StrictHostKeyChecking=accept-new"

# Destination root on Pi
PI_REMOTE_DIR=/home/arcade1/arcade

# Build/restart toggles
PI_BUILD_UI=1
PI_RESTART_INPUT=1
PI_RESTART_KIOSK=1
PI_DAEMON_RELOAD=1
PI_SYNC_RETROARCH_CONFIG=1
# Defaults to "$PI_REMOTE_DIR/os/retroarch.cfg" after rsync
# PI_RETROARCH_CONFIG_SOURCE=/home/arcade1/arcade/os/retroarch.cfg
# If empty, pi-sync auto-detects RETROARCH_CONFIG_PATH from PI_INPUT_SERVICE env.
# Set explicitly if your RetroArch runtime cfg lives elsewhere.
# PI_RETROARCH_CONFIG_PATH=/opt/retropie/configs/all/retroarch.cfg

# Service names on Pi (systemd)
PI_INPUT_SERVICE=arcade-input.service
PI_KIOSK_SERVICE=arcade-ui.service

# Notes:
# - For password login: keep PI_SSH_BATCH_MODE=0
# - For key-only automation: set PI_SSH_BATCH_MODE=1 and PI_SSH_KEY=...


