# Copy to .pi-sync.env and edit values.

# SSH target, e.g. arcade1@192.168.1.50
#10.0.254.13
#192.168.254.196

#192.168.254.120
#10.0.254.8
#arcade1@10.0.254.8
#arcade1@10.0.254.10
#arcade1@arcade-1.local
PI_REMOTE_HOST=arcade1@10.0.254.10
PI_SSH_PORT=22
PI_SSH_BATCH_MODE=0
PI_SSH_KEY=/Users/cplasabas/.ssh/id_ed25519

# Destination root on Pi
PI_REMOTE_DIR=/home/arcade1/arcade

# Build/restart toggles
PI_BUILD_UI=1
PI_RESTART_INPUT=1
PI_RESTART_KIOSK=1

# Service names on Pi (systemd)
PI_INPUT_SERVICE=arcade-input.service
PI_KIOSK_SERVICE=arcade-ui.service

# Optional extra SSH options
# PI_SSH_OPTS="-o BatchMode=yes -o ConnectTimeout=4"
