# Copy to .pi-sync.env and edit values.

# SSH target, e.g. arcade1@192.168.1.50
#10.0.254.13
#192.168.254.196

#192.168.254.120
#10.0.254.8
#arcade1@10.0.254.8
#arcade1@10.0.254.10
#arcade1@10.0.254.12
#arcade1@arcade-1.local
#arcade1@10.0.254.12
#arcade1@192.168.254.163
PI_REMOTE_HOST=arcade1@192.168.254.163
PI_REMOTE_RUNTIME_DIR=/opt/arcade
PI_SSH_PORT=22
PI_SSH_BATCH_MODE=0
PI_SSH_KEY=/Users/cplasabas/.ssh/id_ed25519

PI_BUILD_UI=1
PI_BUILD_INPUT=1
PI_BUILD_UINPUT_HELPER=1
PI_SYNC_OS=1
PI_INSTALL_SYSTEMD_UNITS=1
PI_INSTALL_ETC_FILES=1
PI_DAEMON_RELOAD=1
PI_RESTART_INPUT=1
PI_RESTART_KIOSK=1
PI_SYNC_ROMS=1

PI_INPUT_SERVICE=arcade-input.service
PI_KIOSK_SERVICE=arcade-ui.service
