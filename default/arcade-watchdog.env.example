# Environment file for arcade-watchdog.service. Copy this to /etc/default/arcade-watchdog.env and adjust.

# Chromium running inside startx (monitored by chromosome name more daemon)
CHROMIUM_CMD="/usr/bin/chromium --kiosk --disable-infobars http://127.0.0.1"
CHROMIUM_PATTERN="chromium"
CHROMIUM_LOG="/var/log/arcade-watchdog/chromium.log"

RETROARCH_CMD="/usr/bin/retroarch"
RETROARCH_PATTERN="retroarch"
RETROARCH_LOG="/var/log/arcade-watchdog/retroarch.log"
RETROARCH_STUCK_CPU_THRESHOLD=0.5
RETROARCH_STUCK_CYCLES=8

INPUT_SERVICE_NAME="arcade-input.service"
INPUT_HEALTH_URL="http://127.0.0.1:5174/device-id"
INPUT_HEALTH_TIMEOUT=3
INPUT_FAILURE_RESTART_THRESHOLD=2

NETWORK_CHECK_HOST="1.1.1.1"
NETWORK_CHECK_TIMEOUT=5
NETWORK_FAILURE_RESTART_THRESHOLD=3
NETWORK_FAILURE_REBOOT_THRESHOLD=12
RESTART_NETWORK_COMMAND="nmcli networking off && sleep 2 && nmcli networking on"

DISK_PATH="/"
DISK_USAGE_THRESHOLD=90
DISK_FAILURES_BEFORE_WARNING=3
SMART_DEVICE="/dev/mmcblk0"
SMART_CHECK_INTERVAL=3600

# Optional overrides
# REBOOT_COMMAND="/sbin/shutdown -r now"
# CHECK_INTERVAL=12
