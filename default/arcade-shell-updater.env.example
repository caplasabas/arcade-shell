# Environment variables for the updater service.
#
# Copy this to /etc/default/arcade-shell-updater.env and point to your Supabase project.

SUPABASE_URL="https://rrdnfvbyfjvowiqpgsax.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
ARCADE_SHELL_AUTO_UPDATE="1"
# Optional overrides if you use a different bucket/path layout.
# SUPABASE_STORAGE_BUCKET="game-packages"
# ARCADE_SHELL_METADATA_PATH="arcade-shell/latest.json"
# ARCADE_ROMS_BUCKET="roms"
# ARCADE_ROMS_MANIFEST_PATH="manifest.json"
# ARCADE_ROMS_MANIFEST_URL="https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public/roms/manifest.json"
# ARCADE_ROMS_DIR="/opt/arcade/roms"
# ARCADE_ROMS_AUTO_SYNC="1"
# ARCADE_ROMS_VERIFY_DOWNLOADS="1"
# Override the download/install directories if needed.
# ARCADE_SHELL_DOWNLOAD_DIR="/tmp/arcade-shell"
# ARCADE_SHELL_INSTALL_DIR="/home/arcade1/arcade"

# Required for decrypting the package (must match the key used during packaging).
# GAME_PACKAGE_KEY_HEX="0123456789abcdef... (64 hex chars)"
