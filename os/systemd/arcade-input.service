[Unit]
Description=Arcade Input Service
After=network.target systemd-udev-settle.service arcade-ui.service
Wants=systemd-udev-settle.service arcade-ui.service
StartLimitBurst=5
StartLimitIntervalSec=60

[Service]
Type=simple
User=root
WorkingDirectory=/opt/arcade/service
EnvironmentFile=-/opt/arcade/os/.env.arcade-service

Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/arcade1/.Xauthority
Environment=GAME_PACKAGE_KEY_HEX=e93e36263af461dd686403aa98b20a1e084818359af81258fdb9b17828940620
Environment=ARCADE_RUNTIME_GAMES_DIR=/dev/shm/arcade-games
Environment=ARCADE_RUNTIME_DIR=/opt/arcade
Environment=ARCADE_UI_DIST_DIR=/opt/arcade/ui/dist
Environment=UINPUT_HELPER_PATH=/opt/arcade/bin/uinput-helper

Environment=RETROARCH_TTY_MODE=1
Environment=RETROARCH_SINGLE_X=0
Environment=RETROARCH_RUN_USER=arcade1
Environment=RETROARCH_RUN_UID=1000
Environment=RETROARCH_RUN_HOME=/home/arcade1
Environment=RETROARCH_XDG_RUNTIME_DIR=/run/arcade1
Environment=RETROARCH_DBUS_ADDRESS=
Environment=RETROARCH_PULSE_SERVER=

Environment=RETROARCH_PRIMARY_INPUT=P1
Environment=RETROARCH_CONFIG_PATH=/opt/arcade/os/retroarch.cfg
Environment=CASINO_MENU_EXITS_RETROARCH=1
Environment=ARCADE_RESTART_UI_ON_GAME_EXIT=0
Environment=ARCADE_LIFE_DEDUCT_MODE=unlock_once
Environment=ARCADE_LIFE_START_CONFIRM_WINDOW_MS=2500
Environment=ARCADE_LIFE_PURCHASE_BUTTON_INDEXES=8
Environment=ARCADE_LIFE_PURCHASE_LABEL=BUY
Environment=ARCADE_RETRO_OSD=1
Environment=RETROARCH_NETCMD_PORT=55355
Environment=RETROARCH_OSD_COMMAND=AUTO
Environment=ARCADE_RETRO_OSD_STYLE=footer
Environment=ARCADE_RETRO_OSD_SHOW_SESSION_STATS=0
Environment=ARCADE_RETRO_OSD_PROMPT_PERSIST=1
Environment=ARCADE_RETRO_OSD_PROMPT_INTERVAL_MS=1200
Environment=ARCADE_RETRO_OSD_PROMPT_BLINK=0
Environment=ARCADE_LIFE_BALANCE_SYNC_INTERVAL_MS=1000

ExecStart=/usr/bin/node /opt/arcade/service/input.bundle.js
Restart=always
RestartSec=3
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
