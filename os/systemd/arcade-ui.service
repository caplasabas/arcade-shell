[Unit]
Description=Arcade Xorg + Chromium Kiosk
After=arcade-input.service systemd-user-sessions.service
Requires=arcade-input.service

[Service]
User=arcade1
Environment=DISPLAY=:0
Environment=XAUTHORITY=/home/arcade1/.Xauthority

TTYPath=/dev/tty2
StandardInput=tty
StandardOutput=journal
StandardError=journal
TTYReset=yes
TTYVHangup=yes
TTYVTDisallocate=yes

PermissionsStartOnly=true
ExecStartPre=/opt/arcade/os/bin/arcade-audio-init.sh
ExecStart=/usr/bin/startx /home/arcade1/.xinitrc -- :0 vt2 -nocursor -nolisten tcp
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
